{
  "name": "oneshim-dashboard",
  "version": "0.3.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "qa:pwcli:help": "pnpm exec playwright-cli --help",
    "qa:pwcli:open": "pnpm exec playwright-cli -s=oneshim-qa open http://localhost:10090 --headed --persistent",
    "qa:pwcli:open:preview": "pnpm exec playwright-cli -s=oneshim-qa open http://localhost:10091 --headed --persistent",
    "qa:pwcli:snapshot": "pnpm exec playwright-cli -s=oneshim-qa snapshot",
    "qa:pwcli:show": "pnpm exec playwright-cli show",
    "qa:pwcli:close": "pnpm exec playwright-cli -s=oneshim-qa close",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:live": "playwright test --config playwright-live.config.ts",
    "test:e2e:live:headed": "playwright test --config playwright-live.config.ts --headed",
    "test:e2e:live:report": "playwright show-report playwright-live-report",
    "test:e2e:tauri": "wdio run e2e-tauri/wdio.conf.ts",
    "test:e2e:tauri:watch": "wdio run e2e-tauri/wdio.conf.ts --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@tauri-apps/api": "^2",
    "clsx": "^2.1.1",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.14.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/cli": "^0.1.1",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-themes": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@wdio/cli": "^9.6.1",
    "@wdio/globals": "^9.23.0",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/local-runner": "^9.6.1",
    "@wdio/mocha-framework": "^9.5.1",
    "@wdio/spec-reporter": "^9.5.1",
    "@wdio/types": "^9.24.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "storybook": "^10.2.15",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "webdriverio": "^9.6.1"
  }
}
