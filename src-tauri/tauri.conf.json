{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2/crates/tauri-cli/config.schema.json",
  "productName": "ONESHIM",
  "identifier": "com.oneshim.client",
  "build": {
    "frontendDist": "../crates/oneshim-web/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../crates/oneshim-web/frontend && pnpm dev",
    "beforeBuildCommand": "cd ../crates/oneshim-web/frontend && pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ONESHIM Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false,
        "closable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; connect-src 'self' http://127.0.0.1:*",
      "dangerousDisableAssetCspModification": false
    },
    "trayIcon": {
      "iconPath": "icons/tray_icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    }
  },
  "plugins": {
    "notification": {
      "enabled": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    }
  }
}
